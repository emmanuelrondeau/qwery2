{
	"[astro]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[css]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"files.associations": {
		"*.css": "tailwindcss"
	},
	"editor.formatOnSave": true,
	"tailwindCSS.classAttributes": [
		"class",
		"className",
		"ngClass",
		"class:list"
	],
	"typescript.tsdk": "node_modules/typescript/lib",
	"cSpell.words": [
		"astro",
		"astrojs",
		"benjc",
		"bezier",
		"bowser",
		"bundlemeta",
		"bundlesize",
		"callouts",
		"Cobbs",
		"Consolas",
		"devbox",
		"direnv",
		"embla",
		"flowbite",
		"fontsource",
		"hastscript",
		"herob",
		"jdecked's",
		"Josefin",
		"lqip",
		"mdast",
		"Menlo",
		"nocompatible",
		"Noto",
		"nums",
		"queerwinnipeg",
		"rehype",
		"Rombough",
		"Segoe",
		"stefanprobst",
		"tailwindcss",
		"Twemoji",
		"Wealthsimple",
		"wght"
	]
}
