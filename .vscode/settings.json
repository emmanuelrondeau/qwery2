{
	"[astro]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[css]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[javascript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[json]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[jsonc]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[svelte]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"[typescript]": {
		"editor.defaultFormatter": "biomejs.biome"
	},
	"files.associations": {
		"*.css": "tailwindcss"
	},
	"editor.formatOnSave": true,
	"editor.codeActionsOnSave": {
		"source.organizeImports.biome": "explicit"
	},
	"tailwindCSS.classAttributes": [
		"class",
		"className",
		"ngClass",
		"class:list"
	],
	"tailwindCSS.experimental.classRegex": [
		// https://www.tailwind-variants.org/docs/getting-started#intellisense-setup-optional
		["([\"'`][^\"'`]*.*?[\"'`])", "[\"'`]([^\"'`]*).*?[\"'`]"]
	],
	"typescript.tsdk": "node_modules/typescript/lib",
	"cSpell.words": [
		"adblocking",
		"astro",
		"astrojs",
		"benjc",
		"bezier",
		"bowser",
		"bundlemeta",
		"bundlesize",
		"callouts",
		"CDIC",
		"Cobbs",
		"Consolas",
		"currentcolor",
		"deanonymized",
		"devbox",
		"direnv",
		"embla",
		"figcaption",
		"firewatch",
		"flowbite",
		"fontsource",
		"FOUC",
		"hastscript",
		"herob",
		"imgs",
		"jdecked's",
		"Josefin",
		"KOHO",
		"lavallee",
		"lightbox",
		"lqip",
		"mdast",
		"Menlo",
		"nocompatible",
		"notifs",
		"Noto",
		"nums",
		"Peggo",
		"pharmacare",
		"queerwinnipeg",
		"rehype",
		"rehypei",
		"Rombough",
		"Segoe",
		"stefanprobst",
		"tailwindcss",
		"Tele",
		"Twemoji",
		"WCAG",
		"Wealthsimple",
		"wght",
		"withastro"
	]
}
