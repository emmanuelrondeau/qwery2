{
	"name": "queerwinnipeg.ca",
	"type": "module",
	"version": "0.0.1",
	"packageManager": "pnpm@10.7.0",
	"scripts": {
		"astro": "astro",
		"build": "astro check && astro build",
		"commit": "cz",
		"dev": "astro dev",
		"fmt": "prettier --write ./src ./plugins",
		"lint": "prettier --check ./src ./plugins",
		"preview": "astro preview",
		"start": "astro dev",
		"upgrade-deps": "pnpm upgrade -iL",
		"postinstall": "astro telemetry disable"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.4",
		"@astrojs/cloudflare": "^12.5.0",
		"@astrojs/markdown-remark": "^6.3.1",
		"@astrojs/mdx": "^4.2.4",
		"@astrojs/netlify": "^6.3.0",
		"@astrojs/rss": "^4.0.11",
		"@astrojs/svelte": "^7.0.10",
		"@benjc/rehype-enhanced-tables": "^0.1.1",
		"@fontsource-variable/josefin-sans": "^5.2.5",
		"@stefanprobst/rehype-extract-toc": "^2.2.1",
		"@tailwindcss/vite": "^4.1.3",
		"@twemoji/api": "15.1.0",
		"accessible-astro-components": "^4.1.0",
		"astro": "^5.7.4",
		"astro-auto-import": "^0.4.4",
		"astro-expressive-code": "^0.41.1",
		"astro-seo": "^0.8.4",
		"bigger-picture": "^1.1.19",
		"bits-ui": "^1.3.19",
		"bowser": "^2.11.0",
		"embla-carousel": "^8.5.2",
		"hast-util-select": "^6.0.4",
		"hast-util-to-string": "^3.0.1",
		"hastscript": "^9.0.1",
		"leaflet": "^1.9.4",
		"leaflet-gesture-handling": "^1.2.2",
		"lqip-modern": "^2.2.1",
		"mdast-util-to-string": "^4.0.0",
		"melt": "^0.29.1",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-callouts": "^2.0.2",
		"rehype-slug": "^6.0.0",
		"sharp": "^0.33.5",
		"svelte": "^5.25.9",
		"tailwind-variants": "^1.0.0",
		"tailwindcss": "^4.1.3",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.8.3",
		"unist-util-remove": "^4.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.0",
		"@commitlint/config-conventional": "^19.8.0",
		"@eslint/js": "^9.23.0",
		"@fec/remark-a11y-emoji": "^4.0.2",
		"@herob191/astro-google-fonts-optimizer": "^0.3.3",
		"@melt-ui/pp": "^0.3.2",
		"@melt-ui/svelte": "^0.86.5",
		"@tailwindcss/typography": "^0.5.16",
		"@types/hast": "^3.0.4",
		"@types/leaflet": "^1.9.17",
		"@types/lqip-modern": "^1.1.7",
		"@typescript-eslint/parser": "^8.28.0",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"globals": "^16.0.0",
		"husky": "^9.1.7",
		"phosphor-svelte": "^3.0.1",
		"prettier": "^3.5.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"tailwind-scrollbar": "^4.0.1",
		"typescript-eslint": "^8.29.0",
		"vite-plugin-bundlesize": "^0.1.0"
	},
	"optionalDependencies": {
		"wrangler": "^4.13.2"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"husky": {
		"hooks": {
			"prepare-commit-msg": "exec < /dev/tty && npx cz --hook || true"
		}
	}
}
