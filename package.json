{
	"name": "queerwinnipeg.ca",
	"type": "module",
	"version": "0.0.1",
	"packageManager": "pnpm@10.11.0",
	"scripts": {
		"astro": "astro",
		"build": "astro check && astro build",
		"commit": "cz",
		"dev": "astro dev",
		"fmt": "prettier --write ./src ./plugins",
		"lint": "prettier --check ./src ./plugins",
		"preview": "astro preview",
		"start": "astro dev",
		"upgrade-deps": "pnpm upgrade -iL",
		"postinstall": "astro telemetry disable",
		"wrangler:deploy": "wrangler pages deploy"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.4",
		"@astrojs/cloudflare": "^12.5.3",
		"@astrojs/markdown-remark": "^6.3.2",
		"@astrojs/mdx": "^4.3.0",
		"@astrojs/netlify": "^6.3.4",
		"@astrojs/rss": "^4.0.11",
		"@astrojs/svelte": "^7.1.0",
		"@benjc/rehype-enhanced-tables": "^0.1.1",
		"@fec/remark-a11y-emoji": "^4.0.2",
		"@playform/compress": "^0.1.9",
		"@stefanprobst/rehype-extract-toc": "^3.0.0",
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4.1.8",
		"astro": "^5.8.1",
		"astro-auto-import": "^0.4.4",
		"astro-better-image-service": "^2.1.6",
		"astro-expressive-code": "^0.41.2",
		"astro-seo": "^0.8.4",
		"bigger-picture": "^1.1.19",
		"bits-ui": "^2.4.0",
		"bowser": "^2.11.0",
		"hast-util-select": "^6.0.4",
		"hast-util-to-string": "^3.0.1",
		"hastscript": "^9.0.1",
		"leaflet": "^1.9.4",
		"leaflet-gesture-handling": "^1.2.2",
		"mdast-util-to-string": "^4.0.0",
		"phosphor-svelte": "^3.0.1",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-callouts": "^2.1.0",
		"rehype-slug": "^6.0.0",
		"sharp": "^0.34.2",
		"svelte": "^5.33.11",
		"tailwind-scrollbar": "^4.0.2",
		"tailwind-variants": "^1.0.0",
		"tailwindcss": "^4.1.8",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.8.3",
		"unist-util-remove": "^4.0.0",
		"vite-plugin-bundlesize": "^0.2.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@types/hast": "^3.0.4",
		"@types/leaflet": "^1.9.18",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"husky": "^9.1.7",
		"prettier": "^3.5.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.12"
	},
	"optionalDependencies": {
		"wrangler": "^4.18.0"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"husky": {
		"hooks": {
			"prepare-commit-msg": "exec < /dev/tty && npx cz --hook || true"
		}
	}
}
