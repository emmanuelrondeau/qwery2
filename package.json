{
	"name": "queerwinnipeg.ca",
	"type": "module",
	"version": "0.0.1",
	"packageManager": "pnpm@10.24.0",
	"scripts": {
		"astro": "astro",
		"build": "astro check && astro build",
		"commit": "cz",
		"dev": "astro dev",
		"fmt": "prettier --write ./src ./plugins",
		"lint": "prettier --check ./src ./plugins",
		"preview": "astro preview",
		"start": "astro dev",
		"upgrade-deps": "pnpm upgrade -iL",
		"postinstall": "astro telemetry disable",
		"wrangler:deploy": "wrangler pages deploy",
		"wrangler:deploy-dev": "wrangler pages deploy --branch dev --project-name queerwinnipeg"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.5",
		"@astrojs/cloudflare": "^12.6.11",
		"@astrojs/markdown-remark": "^6.3.9",
		"@astrojs/mdx": "^4.3.12",
		"@astrojs/netlify": "^6.6.2",
		"@astrojs/rss": "^4.0.14",
		"@astrojs/sitemap": "^3.6.0",
		"@astrojs/svelte": "^7.2.2",
		"@benjc/rehype-enhanced-tables": "^0.1.1",
		"@fec/remark-a11y-emoji": "^4.0.2",
		"@iconify-json/material-symbols": "^1.2.47",
		"@iconify-json/ph": "^1.2.2",
		"@playform/compress": "^0.2.0",
		"@stefanprobst/rehype-extract-toc": "^3.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"astro": "^5.16.0",
		"astro-auto-import": "^0.4.5",
		"astro-better-image-service": "2.1.6",
		"astro-expressive-code": "^0.41.3",
		"astro-icon": "^1.1.5",
		"astro-seo": "^0.8.4",
		"bigger-picture": "^1.1.19",
		"bits-ui": "^2.14.4",
		"bowser": "^2.12.1",
		"dotenv": "^17.2.3",
		"hast-util-select": "^6.0.4",
		"hast-util-to-string": "^3.0.1",
		"hastscript": "^9.0.1",
		"leaflet": "^1.9.4",
		"leaflet-gesture-handling": "^1.2.2",
		"mdast-util-to-string": "^4.0.0",
		"phosphor-svelte": "^3.0.1",
		"reading-time": "^1.5.0",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-callouts": "^2.1.2",
		"rehype-slug": "^6.0.0",
		"sharp": "^0.34.5",
		"svelte": "^5.43.14",
		"tailwind-scrollbar": "^4.0.2",
		"tailwind-variants": "^3.1.1",
		"tailwindcss": "^4.1.17",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.9.3",
		"unist-util-remove": "^4.0.0",
		"vite-plugin-bundlesize": "^0.3.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@types/hast": "^3.0.4",
		"@types/leaflet": "^1.9.21",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"husky": "^9.1.7",
		"prettier": "^3.6.2",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.1"
	},
	"optionalDependencies": {
		"wrangler": "^4.50.0"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"husky": {
		"hooks": {
			"prepare-commit-msg": "exec < /dev/tty && npx cz --hook || true"
		}
	}
}
