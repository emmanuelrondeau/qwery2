---
import Head from "@/layouts/Head.astro";
import { Font } from "astro:assets";
---

<!doctype html>
<html
	lang="en"
	transition:name="root"
	transition:animate="none"
	style="color-scheme: light;"
>
	<Head
		seo={{
			title: "零",
			noindex: true,
			nofollow: true,
		}}
	/>
	<Font cssVariable="--font-noto-serif-sc" />
	<body
		class="flex min-h-screen flex-col items-center justify-center bg-black text-gray-50 selection:bg-gray-500/30 selection:text-current"
	>
		<div class="h-full min-h-16 w-full bg-black" role="presentation"></div>
		<main
			class="flex min-h-[429px] w-full flex-col justify-center gap-y-5 bg-[#ef0001] py-24 text-center"
		>
			<h1 class="font-noto-serif-sc text-3xl font-bold" lang="zh-Hans">〇</h1>
			<h2
				class="mx-auto flex w-fit items-center gap-x-4 font-mono text-8xl text-white"
				lang="zh-Hans"
			>
				<span class="relative bottom-1" role="presentation">&#123;</span><span
					class="font-noto-serif-sc text-7xl font-bold">零</span
				><span class="relative bottom-1" role="presentation">&#125;</span>
			</h2>
			<br />
			<h2 class="font-mono text-3xl font-bold text-white uppercase">
				This space<br /> intentionally <br />left blank.
			</h2>
		</main>
		<div class="h-full min-h-16 w-full bg-black" role="presentation"></div>
	</body>
</html>
