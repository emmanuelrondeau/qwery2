---
import { getCollection } from "astro:content";
import ArticleCard from "../../components/articles/ArticleCard.astro";
import Categories from "../../components/categories/Categories.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("posts");

// type Props = {
// 	entry: CollectionEntry<"posts">;
// };

// const mostRecent = posts.sort(
// 	(p) => p.data.lastEdited?.getDate() ?? p.data.created.getDate()
// )[0];
---

<BaseLayout seo={{ title: "Articles" }}>
	<main
		class="format dark:format-invert lg:format-lg mx-auto w-full max-w-screen-xl px-4 pt-24"
	>
		<h1>Articles</h1>
		<p>Neat, articles!</p>
		<Categories />
		<div class="flex flex-col gap-8 md:flex-row">
			<div>
				<ul class="!m-0 flex list-none flex-col gap-6 !p-0 lg:align-middle">
					{
						posts
							.filter((p) => !p.data.draft)
							.map(async (post) => <ArticleCard postId={post.id} />)
					}
				</ul>
			</div>
		</div>
	</main>
</BaseLayout>
