---
import { type CollectionEntry, getCollection, getEntry } from "astro:content";
import ArticleAuthors from "@/components/articles/ArticleAuthors.astro";
import MinutesRead from "@/components/articles/MinutesRead.astro";
import PublishedOrUpdated from "@/components/articles/PublishedOrUpdated.astro";
import TableOfContents from "@/components/articles/table-of-contents/TableOfContents.astro";
import Callout from "@/components/primitives/Callout.astro";
import Link from "@/components/primitives/Link.astro";
import { PAGE_TITLE_ID } from "@/constants";
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import Picture from "@/components/primitives/Picture.astro";

export async function getStaticPaths() {
	const blogEntries = await getCollection("posts");
	return blogEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry: post } = Astro.props;
const { Content, headings } = await post.render();

type Props = {
	entry: CollectionEntry<"posts">;
};

const authorsPromise = post.data.authors.map(async (author) => {
	const authorEntry = await getEntry("authors", author.id);
	if (!authorEntry) throw new Error(`Missing author (author.id ${author.id})`);
	return authorEntry.data;
});
const authors = await Promise.all(authorsPromise);
---

<ArticleLayout
	seo={{
		title: post.data.title,
		description: post.data.description,
		openGraph: {
			basic: {
				image: post.data.cover?.src ?? "",
				title: post.data.title,
				type: "article",
			},
			article: {
				publishedTime: post.data.created.toISOString(),
				modifiedTime: post.data.lastEdited?.toISOString(),
				authors: authors.map((author) => author.name),
				section: post.data.tag,
			},
		},
	}}
	disableFormat
>
	<div
		class="relative mx-auto flex max-w-prose flex-col gap-y-2 px-4 lg:max-w-screen-xl"
	>
		{
			post.data.cover && (
				<div class="relative mx-auto mb-4 flex aspect-video w-full max-w-full items-center justify-center overflow-clip rounded object-cover lg:h-96">
					<Picture
						alt=""
						class="aspect-video h-full w-full rounded object-cover lg:rounded-none"
						src={post.data.cover}
						priority={true}
						layout="full-width"
						formats={["avif"]}
						fallbackFormat="jpg"
						transition:name={`cover-${post.slug}`}
					/>
				</div>
			)
		}
		<div class="format dark:format-invert lg:format-lg !max-w-full">
			{
				post.data.tag && post.data.tag.length > 0 && (
					<Link
						href="/"
						class="not-format mb-3 block font-semibold uppercase no-underline"
					>
						{post.data.tag}
					</Link>
				)
			}
			<h1 id={PAGE_TITLE_ID} class="!mb-4">{post.data.title}</h1>
			<div class="xs:flex-row !mb-4 flex flex-col gap-4 lg:!mb-0">
				<ArticleAuthors postId={post.id} size="large" priority={true} />
				<div class="relative top-[.1em] block">
					<span
						>Written by {authors.map((author) => author.name).join(", ")}</span
					><br />
					<span>
						<PublishedOrUpdated
							lastEdited={post.data.lastEdited}
							created={post.data.created}
						/> •
						<MinutesRead postId={post.id} />
					</span>
				</div>
			</div>
		</div>
		<div
			class="flex w-full flex-col justify-between pt-2 lg:flex-row-reverse lg:pt-0"
		>
			<div
				class="format dark:format-invert top-0 right-0 flex h-fit !max-w-[38ch] min-w-min lg:sticky lg:pl-12 xl:!max-w-prose"
			>
				<TableOfContents headings={headings} />
			</div>
			{/* No idea why this is focusable */}
			<div
				class="format dark:format-invert lg:format-lg block pt-8 outline-offset-2 outline-violet-800 focus-visible:rounded focus-visible:outline-2 dark:outline-violet-50"
			>
				{
					post.data.draft && (
						<Callout type="Warning" typeText="">
							<p>
								<strong>This is a draft post!</strong> It has yet to be
								finalized.
							</p>
						</Callout>
					)
				}
				{
					post.data.containsReferralLinks && (
						<Callout
							type="Info"
							typeText="This article contains affiliate links!"
						>
							<p>
								We receive a commission if you sign up for certain services
								linked below.
							</p>
						</Callout>
					)
				}
				<Content />
			</div>
		</div>
	</div>
</ArticleLayout>

<script>
	import BiggerPicture from "bigger-picture";
	import "bigger-picture/css";

	const bp = BiggerPicture({
		target: document.body,
	});

	const figures = document.querySelectorAll(
		"figure:has(button#bigger-picture)",
	);

	for (const figure of figures) {
		// Go through all the buttons to put the images as "items" for bp to group
		const buttons = figure.getElementsByTagName("button");
		const items: HTMLElement | NodeList | HTMLCollection | item[] = [];
		for (const button of buttons) {
			// Theoretically, there shouldn't be multiple images, but
			// this should still catch cases like this.
			const imgs = button.getElementsByTagName("img");
			for (const img of imgs) {
				// `naturalHeight` isn't fully reliable, but its definitely a
				// fallback that sometimes works. That said, attributes should
				// always have a height and width, assuming the images are local.
				const height = Number(
					img.attributes.getNamedItem("height")?.value ?? img.naturalHeight,
				);
				const width = Number(
					img.attributes.getNamedItem("width")?.value ?? img.naturalWidth,
				);

				items.push({
					height,
					width,
					img: img.src,
					sizes: img.srcset,
					alt: img.alt,
					attr: { class: "" }, // Clears class styling
					element: img,
				});
			}
		}

		// Add the `bp.open` command containing all images in the group
		for (const button of buttons) {
			button.addEventListener("click", (event) => {
				event.preventDefault();
				bp.open({ items });
			});
		}
	}

	// Copied from index.d.ts from bigger-picture
	// cSpell:disable
	interface item {
		[key: string]: any;
		/** Largest possible width of media item in pixels. Not required for HTML, which can be sized via CSS. */
		width?: string | number;
		/** Largest possible height of media item in pixels. Not required for HTML, which can be sized via CSS. */
		height?: string | number;
		/** URL or path to image used for thumbnail displayed before media loads. */
		thumb?: string;
		/** URL or path to full image. Can be a `srcset` value.
		 *
		 * When using `srcset`, the `sizes` value will update automatically when an image is zoomed. You may override this behavior by setting the [`sizes`](https://github.com/henrygd/bigger-picture#sizes) value. */
		img?: string;
		/** For native video and audio, an array of objects specifying [`src`](https://developer.mozilla.org/en-US/docs/Web/HTML/Element/source#attr-src) (required) and [`type`](https://developer.mozilla.org/en-US/docs/Web/HTML/Element/source#attr-type) (optional). A string may be used if it is JSON parsable. Each object will create a `source` element, and all key / value pairs in the object will be added as attributes. */
		sources?: object[] | string;
		/** HTML that will be rendered in the container. When using HTML, please control dimensions with CSS. No need to pass `width` or `height`.
		 *
		 * For advanced use, you can pass an empty string, then mount a component using the [`onOpen`](https://github.com/henrygd/bigger-picture#onopen) method:
		 *
		 * ```js
		 * // mounting svelte component (firewatch example from demo site)
		 * onOpen(container) {
		 *    new Firewatch({
		 *      target: container.querySelector('.bp-html'),
		 *    })
		 * },
		 ``` */
		html?: string;
		/** Image alternative text */
		alt?: string;
		/** URL or path to iframe source */
		iframe?: string;
		/** Title attribute for iframes */
		title?: string;
		/** Text to be displayed using built in caption. You may pass html tags and styles can be overridden via CSS. */
		caption?: string;
		/** Sets the sizes attribute if you're using `srcset`. */
		sizes?: string;
		/** Restricts an image's maximum zoom level to `maxZoom` times the starting size, even if the item's `width` / `height` is larger. For example, a `maxZoom` of 2 on an image that is 800px wide when zoomed out would limit the image to a maximum zoom of 1600px width.
		 *
		 * If `maxZoom` is set on an individual item it will override the value set in options. Attribute name is `data-max-zoom`. */
		maxZoom?: number;
		/** Array of text track data to use with videos. String option is just a stringified array. See the [MDN page on track elements](https://developer.mozilla.org/en-US/docs/Web/HTML/Element/track) for more information. */
		tracks?: string | object[];
		/** To control the default open / close animation, add a property `element` to each item that contains a node on the page. The active item's `element` will be where the animation opens from / closes to. If you're not using the default scale animation, this is not needed. */
		element?: HTMLElement | EventTarget;
		/** Object of attributes to add to the `<img>`, `<iframe>`, `<video>`, `<audio>` elements. */
		attr?: Record<string, string | boolean> | string;
	}
	// cSpell:enable
</script>
<style is:global>
	html.bp-lock {
		/** Needed to fix the TOC from disappearing upon "clicking" a picture
		to enter a lightbox. This causes a non-scrollable horizontal scrollbar
		to appear on Chromium, however. */
		overflow-y: inherit;
	}
</style>
