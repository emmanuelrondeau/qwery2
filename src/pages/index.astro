				<h2 class="lg:text-4xl">Featured</h2>
				<ul
					class="!m-0 flex flex-col gap-x-8 gap-y-6 !ps-0 lg:flex-row"
					role="list"
				>
					<div class="lg:w-1/2 lg:max-w-max">
						<ArticleCard
							size="large"
							postId="how-to-take-the-bus-in-winnipeg.mdx"
							priority={true}
						/>
					</div>
					<div class="flex flex-col gap-6 lg:w-1/2">
						<ArticleCard
							postId="how-to-start-hrt-in-winnipeg.mdx"
							priority={true}
						/>
						<ArticleCard
							postId="how-to-change-your-legal-name-or-sex-in-manitoba.mdx"
							priority={true}
						/>
						<ArticleCard
							postId="save-hundreds-on-your-medications-with-pharmacare-manitoba.mdx"
