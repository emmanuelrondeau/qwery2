import ArticleCard from "@/components/articles/ArticleCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

import RSSPromotion from "@/components/RSSPromotion.astro";
import UmbrellaWithGrass from "@/components/decorations/UmbrellaWithGrass.astro";
import Button from "@/components/primitives/Button.astro";
import StickerRound from "@/components/decorations/sticker-round/StickerRound.svelte";

// const posts = await getCollection("posts");

// type Props = {
// 	entry: CollectionEntry<"posts">;
// };
//
