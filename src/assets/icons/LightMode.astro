---
import { Icon } from "astro-icon/components";

interface Props {
	class?: string;
	width?: number;
}

const { class: className, width } = Astro.props;
---

<Icon
	name="material-symbols:light-mode-outline"
	class:list={["light", className]}
	aria-hidden="true"
	width={width ?? "28px"}
	height={width ?? "28px"}
/>
