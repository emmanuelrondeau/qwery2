---
import "../styles/global.css";

import ThemeProvider from "@/components/primitives/theme/ThemeProvider.astro";
import { SEO, type Props as SEOProps } from "astro-seo";
import { Font } from "astro:assets";

interface Props {
	seo: SEOProps;
	themeColor?: string;
}

const { seo, themeColor } = Astro.props;
const title = seo.title ?? "Queer Winnipeg";
const description =
	seo.description ??
	"Queer Winnipeg is an informal media org, writing articles for our local community and more.";

const newSeoProp: SEOProps = {
	...seo,
	title: `${seo.title} | Queer Winnipeg`,
	description: description,
	openGraph: {
		...seo.openGraph,
		basic: {
			...seo.openGraph?.basic,
			image: seo.openGraph?.basic.image ?? "/favicon@4x.png",
			title: seo.openGraph?.basic.title ?? seo.title ?? title,
			type: seo.openGraph?.basic.type ?? "jpg",
		},
		image: {
			...seo.openGraph?.image,
			url: seo.openGraph?.image?.url ?? "/favicon.svg",
		},
		optional: {
			siteName: "Queer Winnipeg",
			description: description,
		},
	},
	extend: {
		link: [{ rel: "icon", type: "image/svg", href: "/favicon.svg" }],
		meta: [{ name: "theme-color", content: themeColor ?? "#C4B5FD" }],
	},
};
---

<head>
	<meta charset="UTF-8" />
	<SEO {...newSeoProp} />
	<meta name="viewport" content="width=device-width" />
	<meta name="generator" content={Astro.generator} />
	<link rel="sitemap" href="/sitemap-index.xml" />
	<meta
		http-equiv="onion-location"
		content={`http://queerwpgwxrr3e2qcwh52wv4pjqd56lelkkrjxyan6xwimo2a4p6qhid.onion${Astro.url.pathname}`}
	/>
	<Font cssVariable="--font-sans" preload />
	<Font cssVariable="--font-montserrat" preload />
	<link
		rel="alternate"
		type="application/rss+xml"
		title="Queer Winnipeg"
		href={`${Astro.site}rss.xml`}
	/>
	<title>{title}</title>
	<ThemeProvider />
</head>
