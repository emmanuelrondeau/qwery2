---
interface Props {
	lastEdited?: Date;
	created: Date;
}

const { lastEdited, created } = Astro.props;

const displayDate = lastEdited ?? created;
const updatedOrPublished = lastEdited && lastEdited.getDate() != created.getDate() ? "Updated" : "Published";
---

{updatedOrPublished}{" "}
<time datetime={displayDate.toISOString()}
	>{
		displayDate.toLocaleDateString(undefined, {
			dateStyle: "long",
			timeZone: "UTC",
		})
	}</time
>
