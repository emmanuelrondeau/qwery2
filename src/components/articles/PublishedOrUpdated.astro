---
interface Props {
	lastEdited?: Date;
	created: Date;
	prefix?: boolean;
}

const { lastEdited, created, prefix: rawPrefix } = Astro.props;

const prefix = typeof rawPrefix === "boolean" ? rawPrefix : true;
const displayDate = lastEdited ?? created;
const updatedOrPublished = prefix
	? `${
			lastEdited && lastEdited.getDate() !== created.getDate()
				? "Updated"
				: "Published"
		} `
	: "";
---

{updatedOrPublished}<time datetime={displayDate.toISOString()}
	>{
		displayDate.toLocaleDateString(undefined, {
			dateStyle: "long",
			timeZone: "UTC",
		})
	}</time
>
