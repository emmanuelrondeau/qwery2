---
interface Props {
	lastEdited?: Date;
	created: Date;
	prefix?: boolean;
	forcePublished?: boolean;
}

const { lastEdited, created, prefix: rawPrefix, forcePublished } = Astro.props;

const prefix = typeof rawPrefix === "boolean" ? rawPrefix : true;
const displayDate = forcePublished ? created : (lastEdited ?? created);
const updatedOrPublished = prefix
	? `${
			lastEdited && lastEdited.getTime() !== created.getTime()
				? "Updated"
				: "Published"
		} `
	: "";
---

{updatedOrPublished}<time datetime={displayDate.toISOString()}
	>{
		displayDate.toLocaleDateString(undefined, {
			dateStyle: "long",
			timeZone: "UTC",
		})
	}</time
>
