---
import { Picture } from "astro:assets";

interface Props {
	alt: string;
	class?: string | null;
	src: string;
	quality?: "low" | "mid" | "high" | "max";
}
const { src, alt, class: className, quality } = Astro.props;
---

<Picture
	alt={alt}
	class={`flex items-center justify-center rounded-md object-cover shadow mx-auto !h-full !my-0 ${className ?? ""}`}
	src={src}
	loading="lazy"
	decoding="async"
	formats={["avif", "webp"]}
	quality={quality}
	inferSize
/>
