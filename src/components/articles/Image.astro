---
import { Picture } from "astro:assets";

import type { HTMLAttributes } from "astro/types";
interface Props extends HTMLAttributes<"img"> {
	alt: string;
	pictureAttributes: HTMLAttributes<"picture">;
}

const { class: className, pictureAttributes, ...rest } = Astro.props;
---

<button
	id="bigger-picture"
	class="mx-auto flex items-center justify-center rounded-md ring-violet-600 ring-offset-4 ring-offset-white outline-none hover:cursor-pointer focus-visible:ring-2 dark:ring-gray-50 dark:ring-offset-gray-900"
	aria-label="Expand image"
>
	<Picture
		formats={["avif", "webp"]}
		{...rest}
		class:list={[
			"mx-auto !my-0 flex h-auto w-auto items-center justify-center rounded-md object-cover",
			className,
		]}
		pictureAttributes={pictureAttributes ?? { class: "not-format" }}
	/>
</button>
