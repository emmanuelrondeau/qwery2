---
import ImagePrimative from "../primitives/Image.astro";

interface Props {
	alt: string;
	class?: string | null;
	src: ImageMetadata;
	quality?: "low" | "mid" | "high" | "max";
	decoding?: "async" | "auto" | "sync";
	loading?: "lazy" | "eager";
	placeholder?: "blur" | "empty";
}
const {
	src,
	alt,
	class: className,
	quality,
	decoding,
	loading,
	placeholder,
} = Astro.props;
---

<ImagePrimative
	alt={alt}
	class={`flex items-center justify-center rounded-md object-cover shadow mx-auto h-auto w-auto ${className ?? ""}`}
	src={src}
	loading={loading}
	decoding={decoding}
	quality={quality}
	placeholder={placeholder}
/>
