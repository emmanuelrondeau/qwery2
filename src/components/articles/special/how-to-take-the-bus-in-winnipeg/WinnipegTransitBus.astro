---
interface Props {
	type?:
		| "blue"
		| "fx2"
		| "fx3"
		| "fx4"
		| "f"
		| "d"
		| "connector"
		| "default"
		| "on-request";
	text?: string;
	line?: boolean;
	class?: string;
}

const { type: typeProp, text, class: className } = Astro.props;
const type = !typeProp ? "default" : typeProp;
let prefix = "";

switch (type) {
	case "blue":
		prefix = "Blue";
		break;
	case "fx2":
		prefix = "FX2";
		break;
	case "fx3":
		prefix = "FX3";
		break;
	case "fx4":
		prefix = "FX4";
		break;
	case "f":
		prefix = "F";
		break;
	case "d":
		prefix = "D";
		break;
}
---

{
	// Colours are derived from Google Maps. With the exception of FX2, matches https://winnipegtransit.com
	// and/or the GTFS data found at https://gtfs.winnipegtransit.com/google_transit.zip.
}
<span
	class:list={[
		"h-6 rounded-sm px-1.5 font-medium uppercase",
		{ "bg-[#0064b1] text-white": type === "blue" },
		{
			// The hex value Google Maps uses has better contrast (number farthest from 0 is better):
			// - -64.21 Lc - https://contrast.tools?text=ffffff&background=f16122	- Google
			// - -60.13 Lc - https://contrast.tools?text=ffffff&background=f37043 - Winnipeg Transit GTFS
			"bg-[#f16122] text-white": type === "fx2",
		},
		{ "bg-[#f27ea6] text-white": type === "fx3" },
		{ "bg-[#6450a1] text-white": type === "fx4" },
		{ "bg-[#00b262] text-white": type === "f" },
		{ "bg-[#026c7e] text-white": type === "d" },
		{ "bg-[#052465] text-white": type === "connector" },
		{
			"bg-white text-[#072465] ring-1 ring-[#072465] ring-inset":
				type === "default",
		},
		{
			"bg-[#fef6e2] text-[#072465] ring-1 ring-[#072465] ring-inset":
				type === "on-request",
		},
		{ "inline-block": !className?.includes("inline") },
		className,
	]}>{`${prefix}${text ?? ""}`}</span
>
