---
import Image from "../primitives/Image.astro";
import { getCollection } from "astro:content";
import PublishedOrUpdated from "./PublishedOrUpdated.astro";
import MinutesRead from "./MinutesRead.astro";
import ArticleAuthors from "./ArticleAuthors.astro";

interface Props {
	postId: string;
	size?: "small" | "medium" | "large";
}
const { postId }: Props = Astro.props;
const posts = await getCollection("posts");
const post = posts.find((post) => post.id === postId);

if (!post) return;

let { size } = Astro.props;
if (!size) size = "small";
---

<li
	class:list={[
		"!p-0 !m-0 flex xs:items-center gap-4",
		{ "xs:flex-row flex-col": size === "small" },
		{ "flex-col sm:flex-row lg:flex-col": size === "large" },
	]}
>
	<a
		href=`/posts/${post.slug}`
		aria-hidden={true}
		tabindex={-1}
		class:list={[
			{ "flex-shrink-0": size === "small" },
			{ "sm:h-48 sm:w-auto lg:w-full lg:h-auto": size === "large" },
		]}
	>
		<Image
			aria-hidden={true}
			alt=""
			class:list={[
				"not-format transition-transform !m-0 flex object-cover rounded items-center justify-center",
				{
					"sm:hover:scale-105 xs:w-48 xs:h-36 sm:h-auto aspect-video w-full":
						size === "small",
				},
				{
					"sm:hover:scale-[102%] w-full aspect-video sm:aspect-auto sm:h-48 sm:w-auto lg:w-full lg:h-auto lg:aspect-video":
						size === "large",
				},
			]}
			src={post.data.cover}
			loading="eager"
			quality="high"
			widths={[432, 720]}
			sizes=`(max-width: 720px) 720px, (max-width: 1600px) 1000px`
			transition:name=`cover-${post.slug}`
			placeholder="blur"
		/>
	</a>
	{
		size === "small" && (
			<div class="my-auto !m-0 flex-1 min-w-0">
				<a
					href={`/posts/${post.slug}`}
					class="group !no-underline outline-none !ring-0 flex-1 min-w-0"
				>
					{/* Workaround for broken styles if applied to a tag */}
					<h3 class="group-hover:underline !text-xl !mb-1 ring-violet-600 dark:ring-gray-50 group-focus-visible:ring-2 rounded-md lg:text-ellipsis lg:whitespace-nowrap lg:overflow-hidden">
						{post.data.title}
					</h3>
				</a>
				<div class="format dark:format-invert">
					<PublishedOrUpdated {...post.data} /> •{" "}
					<MinutesRead postId={post.id} />
				</div>
				<div class="mt-1">
					<ArticleAuthors postId={post.id} size="small" />
				</div>
			</div>
		)
	}
	{
		size === "large" && (
			<div class="flex flex-col gap-y-3 mr-auto">
				<div class="format dark:format-invert">
					<PublishedOrUpdated {...post.data} /> •{" "}
					<MinutesRead postId={post.id} />
				</div>
				<a
					href={`/posts/${post.slug}`}
					class="group !no-underline outline-none !ring-0"
				>
					{/* Workaround for broken styles if applied to a tag */}
					<h3 class="group-hover:underline !text-xl !mb-0 ring-violet-600 dark:ring-gray-50 group-focus-visible:ring-2 rounded-md">
						{post.data.title}
					</h3>
				</a>
				<p class="!m-0 max-w-prose">
					{post.data.description ?? <i>No description found.</i>}
				</p>
				<ArticleAuthors postId={post.id} size="medium" />
			</div>
		)
	}
</li>
