---
import { getCollection } from "astro:content";

interface Props {
	postId: string;
}
const { postId }: Props = Astro.props;
const posts = await getCollection("posts");
const post = posts.find((post) => post.id === postId);
if (!post) throw new Error(`Post ${postId} not found`);

const renderedPost = await post.render();
const minutesRead: number = renderedPost.remarkPluginFrontmatter.minutesRead;
---

<span>
	<time datetime={`PT${minutesRead}M`}>
		{minutesRead.toLocaleString()}
		<span aria-hidden="true">min</span>
		<span class="sr-only">minute</span>
	</time>
	read
</span>
