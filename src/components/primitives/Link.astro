---
interface Props {
	id?: string;
	href: string;
	target?: "_self" | "_blank";
	referrerpolicy?: "strict-origin-when-cross-origin" | "no-referrer";
	class?: string;
	"aria-hidden"?: boolean;
	tabindex?: number;
	style?: string | null | undefined;
	/**
	 * An "until-hover" state is effectively implied by styling.
	 */
	underlineStyle?: "on-hover" | "never";
	"data-astro-reload"?: boolean;
	"aria-current"?: boolean;
}

const {
	id,
	href,
	target,
	referrerpolicy,
	class: className,
	"aria-hidden": ariaHidden,
	tabindex,
	style,
	underlineStyle,
} = Astro.props;
---

<a
	id={id}
	href={href}
	class:list={[
		className,
		{ "underline-on-hover": underlineStyle === "on-hover" },
	]}
	target={target}
	referrerpolicy={referrerpolicy}
	aria-hidden={ariaHidden}
	tabindex={tabindex}
	data-underline-style={underlineStyle}
	style={style}><slot /></a
>
