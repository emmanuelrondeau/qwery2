---
interface Props {
	id?: string;
	href: string;
	target?: "_self" | "_blank";
	referrerpolicy?: "strict-origin-when-cross-origin" | "no-referrer";
	class?: string;
	"aria-hidden"?: boolean;
	tabindex?: number;
	style?: string | null | undefined;
	"data-astro-reload"?: boolean;
	"aria-current"?: boolean;
}

const {
	id,
	href,
	target,
	referrerpolicy,
	class: className,
	"aria-hidden": ariaHidden,
	tabindex,
	style,
} = Astro.props;
---

<a
	id={id}
	href={href}
	class:list={[
		"ring-focus-outline rounded outline-hidden focus-visible:ring-2",
		className,
	]}
	target={target}
	referrerpolicy={referrerpolicy}
	aria-hidden={ariaHidden}
	tabindex={tabindex}
	style={style}><slot /></a
>
