---
import Background from "../../assets/josh-lavallee-sM0q8DxTkWQ-unsplash-crop.webp";
import Link from "./Link.astro";
import Image from "./Image.astro";
import Button from "./Button.astro";
import ThemeSelector from "./ThemeSelector.astro";
---

<div
	class="pointer-events-none select-none absolute h-[450px] -z-10 dark:hidden"
>
	<div
		class="absolute left-0 right-0 bg-gradient-to-b from-white via-white via-30% h-24"
	>
	</div>
	<Image
		alt=""
		src={Background}
		formats={["avif", "webp", "jpg"]}
		class="object-cover h-full"
		loading="eager"
		quality="high"
	/>
	<div
		class="absolute left-0 right-0 bottom-0 bg-gradient-to-t from-white via-white via-30% h-48"
	>
	</div>
</div>
<nav
	id="main-nav"
	class="flex w-full py-6 z-10"
	transition:animate="none"
	transition:persist
>
	<div
		class="flex max-w-screen-xl w-full px-4 mx-auto items-center justify-between dark:text-gray-50 text-violet-900"
	>
		<Link
			href="/"
			class="text-3xl font-bold select-none text-gray-900 dark:text-gray-50 hover:text-violet-700 dark:hover:text-violet-300 hover:transition-colors"
			><span role="img" aria-label="Logo">QW</span></Link
		>
		<div class="flex items-center gap-x-6">
			<ThemeSelector />
			<Button
				href="https://gitlab.com/queerwinnipeg/queerwinnipeg.ca/-/blob/main/README.md?ref_type=heads#getting-started-for-writers"
				target="_blank">Write for us!</Button
			>
		</div>
	</div>
</nav>
