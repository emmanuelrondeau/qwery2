---
import {
	getConfiguredImageService,
	type LocalImageProps,
	Picture as AstroPicture,
	type RemoteImageProps,
} from "astro:assets";

import type { HTMLAttributes } from "astro/types";
import type { LocalImageServiceWithPlaceholder } from "@/image-service";
import type { ImageOutputFormat } from "astro";

// Somewhat duplicated (with missing props) from Picture.astro
type Props = (LocalImageProps | RemoteImageProps) & {
	formats?: ImageOutputFormat[] | undefined;
	fallbackFormat?: ImageOutputFormat | undefined;
	pictureAttributes?: HTMLAttributes<"picture">;
	/**
	 * @default true
	 */
	placeholder?: boolean;
	/**
	 * If the image has transparency, remove the underlying LQIP background (in
	 * exchange for sending more raw data to the client, and making the client
	 * do more work).
	 * @default false
	 */
	transparent?: boolean;
};

const {
	formats,
	fallbackFormat,
	placeholder: tempPlaceholder,
	transparent: tempTransparent,
	...rest
} = Astro.props;

const placeholder = tempPlaceholder == undefined ? true : tempPlaceholder;
const transparent =
	typeof tempTransparent === "boolean" ||
	tempTransparent === undefined ||
	tempTransparent === null
		? Boolean(tempTransparent)
		: tempTransparent === "true";
let placeholderURL = "";
let isSvg = false;

if (
	process.env.DISABLE_IMAGE_OPTIMIZATION !== "true" &&
	placeholder &&
	typeof Astro.props.src !== "string"
) {
	const resolveSrc = await Promise.resolve(Astro.props.src);
	const src = "default" in resolveSrc ? resolveSrc.default : resolveSrc;
	isSvg = src.format == "svg";

	try {
		// https://github.com/Princesseuh/erika.florist/blob/3a7898d2c168028ba522bf5fb36d1f929392fd67/src/components/Image.astro#L18C1-L24C1
		const imageService =
			(await getConfiguredImageService()) as unknown as LocalImageServiceWithPlaceholder;
		placeholderURL = await imageService.generatePlaceholder(
			src.src,
			src.width,
			src.height,
		);
	} catch (error) {
		const err = error as Error;
		console.log(err);
		throw error;
	}
}
---

<AstroPicture
	{...rest}
	formats={isSvg ? ["svg"] : (formats ?? ["avif"])}
	fallbackFormat={fallbackFormat ?? "jpg"}
	style={placeholderURL
		? `background-size: cover;background-image: url(${placeholderURL});color: transparent;`
		: undefined}
	onload={transparent
		? "requestAnimationFrame(()=>this.style.backgroundImage=null)"
		: undefined}
/>
