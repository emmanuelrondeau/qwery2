---
// This Astro file basically mimics what would otherwise be generated by the
// `remark-callouts` plugin. This excludes `div.callout-inner-title`, because
// it's not needed for titles without icons.

interface Props {
	type: "Info" | "Warning" | "Caution";
	typeText?: string;
}

const { type, typeText } = Astro.props;
---

{
	/**
	 * Callouts should be a div, if WebAIM is to go off by this site, which I'd
	 * wager would be a good example to follow:
	 * https://webaim.org/resources/htmlcheatsheet/
	 */
}
<div class="callout" data-callout={type.toLowerCase()}>
	{
		typeText !== "" && (
			<div class="callout-title">
				{typeText !== undefined ? typeText : `${type}: `}
			</div>
		)
	}
	<div class="callout-content">
		<slot />
	</div>
</div>
