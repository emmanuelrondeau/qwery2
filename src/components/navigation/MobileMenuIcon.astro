---
interface Props {
	width?: number;
}
const { width: tempWidth } = Astro.props;
const width = tempWidth ?? 28;
---

<svg
	width={width}
	height={width}
	viewBox="0 0 24 24"
	xmlns="http://www.w3.org/2000/svg"
	class="label-icon [&_line]:stroke-current [&_line]:stroke-2 [&_line]:transition-all [&_line]:duration-150 [&_line]:ease-[cubic-bezier(0.4,0,0.2,1)]"
	stroke-linecap="square"
	aria-hidden="true"
>
	<line
		class="origin-center group-data-[state=open]:-translate-x-[4px] group-data-[state=open]:translate-y-[4px] group-data-[state=open]:rotate-45"
		x1="3"
		y1="6"
		x2="21"
		y2="6"></line>
	<line
		class="origin-left group-data-[state=open]:-translate-x-2 group-data-[state=open]:opacity-0"
		x1="3"
		y1="12"
		x2="12"
		y2="12"></line>
	<line
		class="origin-right group-data-[state=open]:translate-x-2 group-data-[state=open]:opacity-0"
		x1="12"
		y1="12"
		x2="21"
		y2="12"></line>
	<line
		class="origin-center group-data-[state=open]:-translate-x-[4px] group-data-[state=open]:-translate-y-[4.5px] group-data-[state=open]:-rotate-45"
		x1="3"
		y1="18"
		x2="21"
		y2="18"></line>
</svg>
