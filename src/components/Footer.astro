---
import Link from "./Link.astro";
---

<footer class="bg-white dark:bg-gray-900">
	<div class="mx-auto w-full max-w-screen-xl p-4 py-6 lg:py-8">
		<hr class="my-6 border-gray-200 sm:mx-auto dark:border-gray-700 lg:my-8" />
		<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
			<span
				class="text-sm pb-2 sm:pb-0 font-medium text-gray-500 sm:text-center dark:text-gray-400"
			>
				Made with love, hope, and <a
					href="https://youtu.be/CUgFQv4ocLI?t=7005"
					target="_blank"
					referrerpolicy="no-referrer">joy</a
				> 🩷
			</span>
			<ul
				class="flex flex-wrap items-center mb-6 text-sm font-medium text-gray-500 sm:mb-0 dark:text-gray-400"
			>
				<li>
					<Link
						href="/"
						target="_self"
						referrerpolicy="strict-origin-when-cross-origin"
						class="hover:underline me-4 md:me-6">Home</Link
					>
				</li>
				<li>
					<Link
						href="/posts"
						target="_self"
						class="hover:underline me-4 md:me-6">Articles</Link
					>
				</li>
				<li>
					<Link
						href="https://rainbowresourcecentre.org/programs/social-groups"
						class="hover:underline me-4 md:me-6">Donate</Link
					>
				</li>
				<li>
					<Link
						href="mailto:transfemcircle@rainbowresourcecentre.org"
						class="hover:underline me-4 md:me-6">Email</Link
					>
				</li>
				<li>
					<Link
						href="/privacy"
						target="_self"
						class="hover:underline me-4 md:me-6">Privacy</Link
					>
				</li>
				<li>
					<Link href="#" target="_self" class="hover:underline me-4 md:me-6"
						>Back to Top</Link
					>
				</li>
			</ul>
		</div>
	</div>
</footer>
